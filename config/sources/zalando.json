{
  "id": "zalando",
  "company_name": "Zalando",
  "careers_url": "https://jobs.zalando.com/en/jobs",
  "parser_type": "generic_html",
  "country_hint": "Germany",
  "enabled": true,
  "selectors": {
    "job_card": "main a[href^=\"/en/jobs/\"]",
    "title": "h2",
    "location": "p.text-ellipsis",
    "description": "p.text-primary-black-60"
  },
  "pagination": {
    "strategy": "query_param",
    "max_pages": 8,
    "page_param": "page"
  },
  "job_url_template": "https://jobs.zalando.com/en/jobs/{id}-{slug}"
}
